# Fireworks AI API credentials (required)
# Get your key at https://fireworks.ai/
FIREWORKS_API_KEY=fw_your_api_key_here

# API endpoint (required by entrypoint.py)
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated model IDs; first model is used (required by entrypoint.py)
ALLOWED_MODELS=accounts/fireworks/models/qwen3-vl-8b-instruct

# I/O paths — Docker defaults below; for local runs use input.json / output/results.json
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json

# Parallel video workers
MAX_WORKERS=10
